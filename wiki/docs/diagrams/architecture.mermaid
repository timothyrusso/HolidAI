flowchart TD
    subgraph UI["UI layer"]
        subgraph Components["components/"]
            CT["Component.tsx JSX only"]
            CST["Component.style.ts StyleSheet"]
            CLT["Component.logic.ts ViewModel hook"]
            CT -->|"imports"| CST
            CT -->|"imports"| CLT
        end
    end

    subgraph FHS["Facades / hooks / state"]
        FAC["facade Coordinates repo + useCase"]
        HOK["hook Stateful utility, no repo"]
        STA["state Zustand, client-only"]
    end

    subgraph UC["useCases"]
        USE["XxxUseCase Business logic"]
    end

    subgraph DOM["Domain — pure TypeScript"]
        ENT["entities Interfaces, types"]
        IREP["IXxxRepository Data access contract"]
        ISVC["IXxxService Capability contract"]
        SCH["schemas Zod, type inference"]
    end

    subgraph DAT["Data — external world"]
        HREP["useXxxRepository Hook-based, Convex"]
        CREP["XxxRepository IoC singleton, HTTP"]
        ADA["Adapter DTO to entity"]
        SVC["XxxService IoC singleton, AI/logger"]
        LIB["libraries/ 3rd-party wrappers"]
    end

    CLT -->|"imports"| FAC
    CLT -->|"imports"| HOK
    CLT -->|"imports"| STA
    CLT -.->|"page-specific, not yet promoted"| USE

    FAC -->|"calls"| USE
    FAC -.->|"direct call"| HREP

    USE -->|"depends on"| ENT
    USE -->|"depends on"| IREP
    USE -->|"depends on"| SCH

    IREP -.->|"implemented by"| HREP
    IREP -.->|"implemented by"| CREP

    CREP -->|"depends on"| ISVC
    HREP -->|"depends on"| ISVC
    ISVC -.->|"implemented by"| SVC

    CREP -->|"uses"| ADA
    HREP -->|"uses"| ADA
    SVC -->|"uses"| LIB