flowchart TD
    subgraph UI["UI layer"]
        subgraph Components["components/"]
            CT["Component.tsx\nJSX only"]
            CST["Component.style.ts\nStyleSheet"]
            CLT["Component.logic.ts\nViewModel hook"]
            CT -->|"imports"| CST
            CT -->|"imports"| CLT
        end
    end

    subgraph FHS["Facades / hooks / state"]
        FAC["facade\nCoordinates repo + useCase"]
        HOK["hook\nStateful utility, no repo"]
        STA["state\nZustand, client-only"]
    end

    subgraph UC["useCases"]
        USE["XxxUseCase\nBusiness logic"]
    end

    subgraph DOM["Domain — pure TypeScript"]
        ENT["entities\nInterfaces, types"]
        IREP["IXxxRepository\nData access contract"]
        ISVC["IXxxService\nCapability contract"]
        SCH["schemas\nZod, type inference"]
    end

    subgraph DAT["Data — external world"]
        HREP["useXxxRepository\nHook-based, Convex"]
        CREP["XxxRepository\nIoC singleton, HTTP"]
        ADA["Adapter\nDTO to entity"]
        SVC["XxxService\nIoC singleton, AI/logger"]
        LIB["libraries/\n3rd-party wrappers"]
    end

    CLT -->|"imports"| FAC
    CLT -->|"imports"| HOK
    CLT -->|"imports"| STA
    CLT -.->|"page-specific, not yet promoted"| USE

    FAC -->|"calls"| USE
    FAC -.->|"direct call"| HREP

    USE -->|"depends on"| ENT
    USE -->|"depends on"| IREP
    USE -->|"depends on"| SCH

    IREP -.->|"implemented by"| HREP
    IREP -.->|"implemented by"| CREP

    CREP -->|"depends on"| ISVC
    HREP -->|"depends on"| ISVC
    ISVC -.->|"implemented by"| SVC

    CREP -->|"uses"| ADA
    HREP -->|"uses"| ADA
    SVC -->|"uses"| LIB