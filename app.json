{
  "expo": {
    "name": "HolidAI",
    "slug": "holidai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./features/core/ui/assets/images/icon.png",
    "scheme": "holidai",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./features/core/ui/assets/images/logo_round.png",
      "resizeMode": "contain",
      "backgroundColor": "#220059"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.app.travelplanner",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.app.travelplanner",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./features/core/ui/assets/images/android-icon.png",
        "backgroundColor": "#220059"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./features/core/ui/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "react-native-map-link",
      "expo-font",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#220059",
          "image": "./features/core/ui/assets/images/logo_round.png",
          "dark": {
            "image": "./features/core/ui/assets/images/logo_round.png",
            "backgroundColor": "#220059"
          },
          "ios": {
            "imageWidth": 100,
            "resizeMode": "contain"
          },
          "android": {
            "imageWidth": 150
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "timothyrussodev"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "23b4e2dd-269e-4fdc-a235-8e0d9e28b886"
      }
    },
    "owner": "holidai"
  }
}
